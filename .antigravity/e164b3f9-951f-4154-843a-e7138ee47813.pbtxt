          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Draw gradient tail"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const tailSlices = 40;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      for (let i = 0; i < tailSlices; i++) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const sliceAngle = sweepRad - (i * 0.02);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const opacity = (1 - i / tailSlices) * 0.15;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ctx.fillStyle = isBoba "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          ? `rgba(251,113,133,${opacity})` "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          : `rgba(167,139,250,${opacity})`;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ctx.beginPath();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ctx.moveTo(cx, cy);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ctx.arc(cx, cy, R, sliceAngle, sliceAngle + 0.02);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ctx.closePath();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ctx.fill();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
