        lines {
          text: "// Seeded pseudorandom generator to maintain consistent fake locations on drag"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "function seededRandom(seed: number) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const x = Math.sin(seed++) * 10000;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  return x - Math.floor(x);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
