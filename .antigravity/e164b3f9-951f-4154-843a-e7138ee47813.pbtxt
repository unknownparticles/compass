          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        } else {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          // Cyberpunk blip style (Neon green/violet core)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          const baseColor = isSelected ? \'rgba(232,121,249,1)\' : \'rgba(139,92,246,0.5)\';"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
