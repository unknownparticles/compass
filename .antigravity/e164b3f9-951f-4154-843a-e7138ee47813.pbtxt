        }
        lines {
          text: "  const ad = distanceM / R;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const rla1 = (lat * Math.PI) / 180;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const rlo1 = (lng * Math.PI) / 180;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const rbearing = (bearingDeg * Math.PI) / 180;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const rla2 = Math.asin("
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    Math.sin(rla1) * Math.cos(ad) + Math.cos(rla1) * Math.sin(ad) * Math.cos(rbearing)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const rlo2 ="
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    rlo1 +"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    Math.atan2("
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      Math.sin(rbearing) * Math.sin(ad) * Math.cos(rla1),"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      Math.cos(ad) - Math.sin(rla1) * Math.sin(rla2)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  return {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    lat: (rla2 * 180) / Math.PI,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    lng: (rlo2 * 180) / Math.PI"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  };"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
