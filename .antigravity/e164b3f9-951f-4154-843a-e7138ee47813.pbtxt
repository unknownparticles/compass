    replacement_chunks {
      target_content: "import React from \'react\';\nimport { motion, AnimatePresence } from \'motion/react\';\nimport { Compass, Navigation, ArrowUp, RefreshCw, Beer, Coffee, MapPin } from \'lucide-react\';\nimport { Shop, CompassMode } from \'../types\';\n\ninterface CompassProps {\n  mode: CompassMode;\n  userHeading: number;\n  setUserHeading: (heading: number) => void;\n  selectedShop: Shop | null;\n  sensorStatus: \'active\' | \'unavailable\' | \'loading\';\n  requestDeviceOrientation: () => void;\n}\n\nexport default function CompassView({\n  mode,\n  userHeading,\n  setUserHeading,\n  selectedShop,\n  sensorStatus,\n  requestDeviceOrientation\n}: CompassProps) {\n  // Angle calculations:\n  // bearing: absolute angle of target (0 is North)\n  // userHeading: absolute angle user is facing (0 is North)\n  // To point to target, the arrow rotates relative to the device screen: (bearing - userHeading)\n  const targetBearing = selectedShop ? selectedShop.bearing : 0;\n  const relativeAngle = selectedShop ? (targetBearing - userHeading + 360) % 360 : 0;\n\n  // Formatting helper for heading\n  const getCardinalDirection = (deg: number) => {\n    const directions = [\'\345\214\227 (N)\', \'\344\270\234\345\214\227 (NE)\', \'\344\270\234 (E)\', \'\344\270\234\345\215\227 (SE)\', \'\345\215\227 (S)\', \'\350\245\277\345\215\227 (SW)\', \'\350\245\277 (W)\', \'\350\245\277\345\214\227 (NW)\'];\n    const idx = Math.round(deg / 45) % 8;\n    return directions[idx];\n  };\n\n  // Preset quick headings\n  const setFacing = (deg: number) => {\n    setUserHeading(deg);\n  };\n\n  const isBoba = mode === \'milktea\';\n\n  return (\n    <div className=\"flex flex-col items-center justify-center w-full max-w-md mx-auto px-4 py-6\">\n      {/* Sensor Status Banner */}\n      <div className={`w-full flex items-center justify-between px-4 py-2.5 rounded-2xl mb-6 text-xs font-medium border transition-colors ${\n        isBoba \n          ? \'bg-rose-50/80 border-rose-100 text-rose-700\' \n          : \'bg-indigo-950/40 border-indigo-900/60 text-indigo-300\'\n      }`}>\n        <div className=\"flex items-center gap-2\">\n          <span className={`w-2 h-2 rounded-full ${\n            sensorStatus === \'active\' \n              ? \'bg-emerald-500 animate-pulse\' \n              : \'bg-amber-500\'\n          }`} />\n          <span>\346\211\213\346\234\272\351\231\200\350\236\272\344\273\252\357\274\232{sensorStatus === \'active\' ? \'\345\267\262\350\277\236\346\216\245 (\345\256\236\346\227\266\346\214\207\345\220\221)\' : \'\344\270\215\345\217\257\347\224\250 (\350\231\232\346\213\237\346\250\241\346\213\237)\'}</span>\n        </div>\n        {sensorStatus !== \'active\' ? (\n          <button \n            id=\"auth-gyro\"\n            onClick={requestDeviceOrientation}\n            className={`flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-[11px] font-semibold cursor-pointer border transition-all hover:scale-105 ${\n              isBoba \n                ? \'bg-rose-100 hover:bg-rose-200 border-rose-200 text-rose-800\' \n                : \'bg-indigo-800 hover:bg-indigo-700 border-indigo-700 text-indigo-100\'\n            }`}\n          >\n            <RefreshCw className=\"w-3 h-3 animate-spin\" style={{ animationDuration: \'4s\' }} />\n            <span>\345\274\200\345\220\257\347\234\237\346\234\272\346\214\207\345\220\221</span>\n          </button>\n        ) : (\n          <span className=\"opacity-70\">\347\234\237\346\234\272\345\212\250\346\200\201\346\204\237\345\272\224\344\270\255</span>\n        )}\n      </div>"
      replacement_content: "import React, { useState } from \'react\';\nimport { motion, AnimatePresence } from \'motion/react\';\nimport { Compass, Navigation, ArrowUp, RefreshCw, Beer, Coffee, MapPin, AlertCircle, ExternalLink, HelpCircle } from \'lucide-react\';\nimport { Shop, CompassMode } from \'../types\';\n\ninterface CompassProps {\n  mode: CompassMode;\n  userHeading: number;\n  setUserHeading: (heading: number) => void;\n  selectedShop: Shop | null;\n  sensorStatus: \'active\' | \'unavailable\' | \'loading\';\n  requestDeviceOrientation: () => void;\n  isInIframe: boolean;\n}\n\nexport default function CompassView({\n  mode,\n  userHeading,\n  setUserHeading,\n  selectedShop,\n  sensorStatus,\n  requestDeviceOrientation,\n  isInIframe\n}: CompassProps) {\n  const [showDiagnostic, setShowDiagnostic] = useState<boolean>(true);\n\n  // Angle calculations:\n  // bearing: absolute angle of target (0 is North)\n  // userHeading: absolute angle user is facing (0 is North)\n  // To point to target, the arrow rotates relative to the device screen: (bearing - userHeading)\n  const targetBearing = selectedShop ? selectedShop.bearing : 0;\n  const relativeAngle = selectedShop ? (targetBearing - userHeading + 360) % 360 : 0;\n\n  // Formatting helper for heading\n  const getCardinalDirection = (deg: number) => {\n    const directions = [\'\345\214\227 (N)\', \'\344\270\234\345\214\227 (NE)\', \'\344\270\234 (E)\', \'\344\270\234\345\215\227 (SE)\', \'\345\215\227 (S)\', \'\350\245\277\345\215\227 (SW)\', \'\350\245\277 (W)\', \'\350\245\277\345\214\227 (NW)\'];\n    const idx = Math.round(deg / 45) % 8;\n    return directions[idx];\n  };\n\n  // Preset quick headings\n  const setFacing = (deg: number) => {\n    setUserHeading(deg);\n  };\n\n  const isBoba = mode === \'milktea\';\n\n  return (\n    <div className=\"flex flex-col items-center justify-center w-full max-w-md mx-auto px-4 py-6\">\n      \n      {/* Sensor Status Banner */}\n      <div className={`w-full flex items-center justify-between px-4 py-2.5 rounded-2xl mb-4 text-xs font-medium border transition-colors ${\n        sensorStatus === \'active\'\n          ? \'bg-emerald-500/10 border-emerald-500/20 text-emerald-600 dark:text-emerald-400\'\n          : isBoba \n            ? \'bg-rose-50/80 border-rose-100 text-rose-700\' \n            : \'bg-indigo-950/40 border-indigo-900/60 text-indigo-300\'\n      }`}>\n        <div className=\"flex items-center gap-2\">\n          <span className={`w-2.5 h-2.5 rounded-full ${\n            sensorStatus === \'active\' \n              ? \'bg-emerald-500 animate-pulse\' \n              : \'bg-amber-500 animate-pulse\'\n          }`} />\n          <span>\346\211\213\346\234\272\351\231\200\350\236\272\344\273\252\357\274\232{sensorStatus === \'active\' ? \'\345\267\262\350\277\236\346\216\245 (\345\256\236\346\227\266\346\214\207\345\220\221)\' : \'\344\270\215\345\217\257\347\224\250 (\350\231\232\346\213\237\346\250\241\346\213\237)\'}</span>\n        </div>\n        {sensorStatus !== \'active\' ? (\n          <button \n            id=\"auth-gyro\"\n            onClick={requestDeviceOrientation}\n            className={`flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-[11px] font-semibold cursor-pointer border transition-all hover:scale-105 active:scale-95 ${\n              isBoba \n                ? \'bg-rose-100 hover:bg-rose-200 border-rose-200 text-rose-800\' \n                : \'bg-indigo-800 hover:bg-indigo-700 border-indigo-700 text-indigo-100\'\n            }`}\n          >\n            <RefreshCw className=\"w-3 h-3\" />\n            <span>\345\274\200\345\220\257\347\234\237\346\234\272\346\214\207\345\220\221</span>\n          </button>\n        ) : (\n          <span className=\"opacity-70 text-[11px]\">\347\234\237\346\234\272\345\212\250\346\200\201\346\204\237\345\272\224\344\270\255</span>\n        )}\n      </div>\n\n      {/* Sensor Diagnostic & Instruction Guide */}\n      {sensorStatus !== \'active\' && showDiagnostic && (\n        <motion.div\n          initial={{ opacity: 0, y: -8 }}\n          animate={{ opacity: 1, y: 0 }}\n          className={`w-full p-4 rounded-2xl border text-left mb-6 text-xs relative ${\n            isBoba \n              ? \'bg-orange-50/60 border-orange-100/80 text-rose-950\' \n              : \'bg-indigo-950/20 border-indigo-950 text-indigo-300\'\n          }`}\n        >\n          <div className=\"flex items-start gap-2.5\">\n            <AlertCircle className=\"w-4 h-4 shrink-0 text-amber-500 mt-0.5\" />\n            <div className=\"space-y-1.5\">\n              <h4 className=\"font-extrabold flex items-center gap-1\">\n                <span>\344\270\272\344\273\200\344\271\210\346\210\221\347\232\204\346\211\213\346\234\272\351\231\200\350\236\272\344\273\252\344\270\215\345\217\257\347\224\250\357\274\237</span>\n                <span className=\"px-1.5 py-0.5 rounded bg-amber-500/10 text-amber-600 text-[9px] font-black uppercase\">\n                  \346\212\200\346\234\257\347\247\221\346\231\256\344\270\216\344\277\256\345\244\215\n                </span>\n              </h4>\n              <p className=\"leading-relaxed opacity-90\">\n                {isInIframe ? (\n                  <>\n                    \342\232\240\357\270\217 <strong>\346\243\200\346\265\213\345\210\260\345\275\223\345\211\215\345\234\250 AI Studio \346\241\206\346\236\266\344\270\255\350\277\220\350\241\214\357\274\232</strong>\347\224\261\344\272\216\346\265\217\350\247\210\345\231\250\347\232\204\346\262\231\347\233\222\345\256\211\345\205\250\350\247\204\345\210\231\357\274\214\345\265\214\345\245\227\345\234\250 iFrame \345\206\205\347\232\204\347\275\221\351\241\265\350\242\253\347\273\235\345\257\271\347\246\201\346\255\242\350\257\273\345\217\226\351\207\215\345\212\233\345\212\240\351\200\237\345\272\246\350\256\241\344\270\216\347\275\227\347\233\230\343\200\202\n                  </>\n                ) : (\n                  <>\n                    \342\232\240\357\270\217 <strong>\344\274\240\346\204\237\345\231\250\350\242\253\346\213\246\346\210\252\357\274\232</strong>\347\247\273\345\212\250\347\253\257\346\265\217\350\247\210\345\231\250\357\274\210iOS Safari \344\270\216 Chrome\357\274\211\350\246\201\346\261\202\345\277\205\351\241\273\345\234\250<strong> HTTPS \345\256\211\345\205\250\350\277\236\346\216\245</strong>\344\270\213\357\274\214\344\270\224\351\200\232\350\277\207<strong>\347\224\250\346\210\267\346\211\213\345\212\250\347\202\271\345\207\273</strong>\346\211\215\350\203\275\346\216\210\346\235\203\350\260\203\347\224\250\347\275\227\347\233\230\343\200\202\n                  </>\n                )}\n              </p>\n              \n              <div className=\"pt-1.5 border-t border-dashed border-current/10 space-y-1\">\n                <p className=\"font-bold\">\360\237\233\240\357\270\217 \345\256\214\347\276\216\344\277\256\345\244\215\345\271\266\345\220\257\347\224\250\347\234\237\346\234\272\346\255\245\351\252\244\357\274\232</p>\n                <ol className=\"list-decimal list-inside space-y-1 pl-1 opacity-90\">\n                  {isInIframe && (\n                    <li>\n                      \347\202\271\345\207\273\345\261\217\345\271\225\345\217\263\344\270\212\350\247\222 <strong>\342\200\234\345\234\250\346\226\260\346\240\207\347\255\276\351\241\265\344\270\255\346\211\223\345\274\200 (Open in a new tab)\342\200\235</strong> \347\213\254\347\253\213\351\241\265\351\235\242\343\200\202\n                    </li>\n                  )}\n                  <li>\344\275\277\347\224\250\346\211\213\346\234\272\345\276\256\344\277\241\346\210\226\350\207\252\345\270\246\346\265\217\350\247\210\345\231\250\346\211\253\347\240\201\347\213\254\347\253\213\351\241\265\351\235\242\347\232\204 URL\343\200\202</li>\n                  <li>\n                    \350\277\233\345\205\245\346\211\213\346\234\272\346\265\217\350\247\210\345\231\250\345\220\216\357\274\214\347\202\271\345\207\273\344\270\212\346\226\271\351\227\252\347\203\201\347\232\204 <strong>\343\200\220\345\274\200\345\220\257\347\234\237\346\234\272\346\214\207\345\220\221\343\200\221</strong> \346\214\211\351\222\256\357\274\214\345\271\266\345\205\201\350\256\270\345\212\250\344\275\234\344\270\216\346\226\271\345\220\221\346\235\203\351\231\220\357\274\214\347\275\227\347\233\230\345\215\263\345\217\257\347\236\254\351\227\264\350\242\253\346\277\200\346\264\273\357\274\201\n                  </li>\n                </ol>\n              </div>\n              \n              <p className=\"text-[10px] opacity-75 italic mt-1.5\">\n                \360\237\222\241 \347\224\265\350\204\221\347\253\257\346\210\226\346\234\252\345\274\200\345\220\257\346\227\266\357\274\214\346\202\250\344\276\235\347\204\266\345\217\257\344\273\245\345\256\214\347\276\216\346\213\226\345\212\250\344\270\213\346\226\271\347\232\204<b>\342\200\234\345\275\223\345\211\215\351\235\242\346\234\235\346\226\271\345\220\221\342\200\235\346\273\221\345\235\227</b>\345\222\214\344\275\277\347\224\250<b>\350\277\220\345\212\250\346\250\241\346\213\237\345\231\250</b>\350\277\233\350\241\214\345\256\214\347\276\216\347\232\204\350\231\232\346\213\237\350\241\214\350\265\260\345\222\214\351\233\267\350\276\276\345\257\273\345\272\227\346\265\213\350\257\225\357\274\201\n              </p>\n            </div>\n          </div>\n        </motion.div>\n      )}"
    }
