        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // 3. Render User Facing direction indicator (a dashed white cone representing user\'s view)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const headingRad = ((userHeading - 90) * Math.PI) / 180; // 0 deg is UP (-90 degrees in standard polar)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const fieldOfView = (45 * Math.PI) / 180; // 45 degree vision cone"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.strokeStyle = isBoba ? \'rgba(253,186,116,0.35)\' : \'rgba(232,121,249,0.3)\';"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.lineWidth = 1;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.setLineDash([4, 4]);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.beginPath();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.moveTo(cx, cy);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.arc(cx, cy, R, headingRad - fieldOfView / 2, headingRad + fieldOfView / 2);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.closePath();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.stroke();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.setLineDash([]); // reset"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // 4. Update and Draw Blips (Shops)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      shops.forEach((shop) => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Map bearing to standard polar coordinates (0 is North/UP, which is -90 degrees)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const shopAngleRad = ((shop.bearing - 90) * Math.PI) / 180;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Calculate screen coordinates"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const ratio = Math.min(shop.distance / 1000, 1.0); // max 1km on radar"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const bx = cx + R * ratio * Math.cos(shopAngleRad);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const by = cy + R * ratio * Math.sin(shopAngleRad);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Normalize angles to check if sweep overlaps with this shop"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Standard angle values are 0 to 2PI"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const normalizedSweep = (sweepRad + Math.PI * 2) % (Math.PI * 2);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const normalizedShopAngle = (shopAngleRad + Math.PI * 2) % (Math.PI * 2);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Check distance between sweep line angle and shop angle"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        let angleDiff = Math.abs(normalizedSweep - normalizedShopAngle);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        if (angleDiff > Math.PI) angleDiff = Math.PI * 2 - angleDiff;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // If sweep line is crossing the blip (within ~2 degrees / 0.035 rad), illuminate it fully"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        if (angleDiff < 0.04) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          blipIlluminationsRef.current[shop.id] = 1.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        } else {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          // Slowly decay the light level"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          const currentIllum = blipIlluminationsRef.current[shop.id] || 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          blipIlluminationsRef.current[shop.id] = Math.max(0, currentIllum * 0.985 - 0.003);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const illum = blipIlluminationsRef.current[shop.id] || 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Draw glow halos around the blips"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const isSelected = selectedShop?.id === shop.id;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const radius = isSelected ? 7 : 5;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        if (isSelected) {"
