        lines {
          text: "// Haversine formula to calculate distance in meters"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "export function getDistance(lat1: number, lng1: number, lat2: number, lng2: number): number {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const R = 6371e3; // meters"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const phi1 = (lat1 * Math.PI) / 180;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const phi2 = (lat2 * Math.PI) / 180;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const deltaPhi = ((lat2 - lat1) * Math.PI) / 180;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const deltaLambda = ((lng2 - lng1) * Math.PI) / 180;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const a ="
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    Math.sin(deltaPhi / 2) * Math.sin(deltaPhi / 2) +"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    Math.cos(phi1) * Math.cos(phi2) *"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    Math.sin(deltaLambda / 2) * Math.sin(deltaLambda / 2);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  return R * c; // in meters"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// Calculate bearing/absolute angle (0 = North, 90 = East, 180 = South, 270 = West)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "export function getBearing(lat1: number, lng1: number, lat2: number, lng2: number): number {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const phi1 = (lat1 * Math.PI) / 180;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const phi2 = (lat2 * Math.PI) / 180;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const lambda1 = (lng1 * Math.PI) / 180;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const lambda2 = (lng2 * Math.PI) / 180;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const y = Math.sin(lambda2 - lambda1) * Math.cos(phi2);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const x ="
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    Math.cos(phi1) * Math.sin(phi2) -"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    Math.sin(phi1) * Math.cos(phi2) * Math.cos(lambda2 - lambda1);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const brng = (Math.atan2(y, x) * 180) / Math.PI;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  return (brng + 360) % 360; // normalized to 0-360"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
