          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Draw sharp sweep line"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.strokeStyle = isBoba ? \'rgba(244,63,94,0.6)\' : \'rgba(167,139,250,0.7)\';"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.lineWidth = 1.5;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.beginPath();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.moveTo(cx, cy);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.lineTo(cx + R * Math.cos(sweepRad), cy + R * Math.sin(sweepRad));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
