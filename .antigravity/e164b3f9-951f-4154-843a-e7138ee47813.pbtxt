        }
        lines {
          text: "      // Draw concentric circles (representing 200m, 500m, 800m, 1000m)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const circles = [0.2, 0.5, 0.8, 1.0];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      circles.forEach((multiplier) => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ctx.beginPath();"
