          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.moveTo(cx, cy - R);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.lineTo(cx, cy + R);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
