        }
        lines {
          text: "      ctx.strokeStyle = isBoba ? \'rgba(251,113,133,0.15)\' : \'rgba(139,92,246,0.15)\';"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
