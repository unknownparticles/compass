        lines {
          text: "      ctx.stroke();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Draw angular indicators (30, 60, 120, 150 etc.)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.strokeStyle = isBoba ? \'rgba(251,113,133,0.06)\' : \'rgba(139,92,246,0.06)\';"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      [30, 60, 120, 150, 210, 240, 300, 330].forEach((deg) => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const rad = (deg * Math.PI) / 180;"
