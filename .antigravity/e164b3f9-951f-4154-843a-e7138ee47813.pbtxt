        }
        lines {
          text: "        ctx.lineTo(cx + R * Math.cos(rad), cy + R * Math.sin(rad));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ctx.stroke();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // 2. Draw sweeping beam"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Sweep rotates clockwise."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      sweepAngleRef.current = (sweepAngleRef.current + 0.02) % (Math.PI * 2);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const sweepRad = sweepAngleRef.current;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
