          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ctx.fillStyle = isBoba ? \'rgba(244,63,94,0.6)\' : \'rgba(139,92,246,0.6)\';"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ctx.font = \'9px monospace\';"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ctx.fillText(`${Math.round(multiplier * 1000)}m`, cx + 4, cy - R * multiplier + 10);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
